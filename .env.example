# AcademicForge environment template
# Copy to .env, then uncomment and fill only the values you need.
# Never commit real keys.

# Hugging Face token for gated models such as Gemma.
# HF_TOKEN=PASTE_YOUR_HUGGING_FACE_TOKEN_HERE

# Fireworks key. When set, Research Plan generation uses DeepSeek through Fireworks.
# FIREWORKS_API_KEY=PASTE_YOUR_FIREWORKS_KEY_HERE

# Runtime selection.
# auto = MLX on Apple Silicon, Transformers elsewhere.
LOCAL_LLM_PROVIDER=auto

# Fast Mode local model.
# On AMD/ROCm this is the Transformers model.
LOCAL_LLM_MODEL=google/gemma-2-2b-it

# Apple Silicon MLX equivalent is selected automatically by code when no explicit
# model is set. Keep LOCAL_LLM_MODEL above for the AMD/ROCm demo path.

# Optional explicit Deep/Research Plan model.
# If FIREWORKS_API_KEY is set and this is left commented, the app uses:
# accounts/fireworks/models/deepseek-v4-pro
# LOCAL_LLM_DEEP_MODEL=accounts/fireworks/models/deepseek-v4-pro
# LOCAL_LLM_RESEARCH_PLAN_MODEL=accounts/fireworks/models/deepseek-v4-pro

LOCAL_LLM_MAX_TOKENS=2500
LOCAL_LLM_TEMPERATURE=0.2

# Streamlit -> FastAPI backend URL.
ACADEMICFORGE_BACKEND_URL=http://127.0.0.1:8000

# Retrieval device. auto uses GPU when PyTorch exposes one.
# ACADEMICFORGE_RETRIEVAL_DEVICE=auto
# ACADEMICFORGE_RETRIEVAL_DEVICE=cpu

# Preload local model and retrieval weights before starting the app.
ACADEMICFORGE_PRELOAD_WEIGHTS=true
