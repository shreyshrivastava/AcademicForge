# ==============================================================================
# AcademicForge - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and edit the variables below to match your environment.
# Note: Do not commit actual credentials or secrets to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM Inference Provider Configurations
# ------------------------------------------------------------------------------
# The inference backend engine to use for local generation.
# Allowed values:
#   - mlx          : Native Apple Silicon hardware-accelerated serving (macOS only)
#   - transformers : PyTorch backend (supports AMD ROCm, NVIDIA CUDA, or CPU fallback)
#   - openai       : OpenAI API (requires OPENAI_API_KEY)
#   - fireworks    : Fireworks API (requires FIREWORKS_API_KEY)
# Default: mlx
LOCAL_LLM_PROVIDER=mlx

# ------------------------------------------------------------------------------
# API Key Credentials (for Cloud API Providers)
# ------------------------------------------------------------------------------
# Set the respective key below if LOCAL_LLM_PROVIDER is set to 'openai' or 'fireworks'.
# DO NOT commit actual keys to version control.
# OPENAI_API_KEY=
# FIREWORKS_API_KEY=

# ------------------------------------------------------------------------------
# Model Configurations (Fast Mode / Deep Mode)
# ------------------------------------------------------------------------------
# The model used for Fast Mode.
# Default: mlx-community/Qwen3-4B-4bit
LOCAL_LLM_MODEL=mlx-community/Qwen3-4B-4bit

# The model used specifically to generate concise paper summaries.
# If left blank, defaults to LOCAL_LLM_MODEL.
LOCAL_LLM_SUMMARY_MODEL=mlx-community/Qwen3-4B-4bit

# The model used specifically for paper guidance (Builder Guidance).
# If left blank, defaults to LOCAL_LLM_ROADMAP_MODEL or LOCAL_LLM_MODEL.
LOCAL_LLM_GUIDANCE_MODEL=mlx-community/gemma-4-e2b-it-OptiQ-4bit

# The model used specifically for detailed Research Plans (Deep Mode).
# If left blank, defaults to LOCAL_LLM_ROADMAP_MODEL or LOCAL_LLM_MODEL.
LOCAL_LLM_RESEARCH_PLAN_MODEL=mlx-community/gemma-4-e2b-it-OptiQ-4bit

# ------------------------------------------------------------------------------
# LLM Inference Parameters
# ------------------------------------------------------------------------------
# The maximum token budget allocated for each LLM generation response.
# Default: 700
LOCAL_LLM_MAX_TOKENS=700

# The generation temperature to control output creativity (lower is more deterministic).
# Default: 0.2
LOCAL_LLM_TEMPERATURE=0.2

# ------------------------------------------------------------------------------
# Persistent Caching Configurations
# ------------------------------------------------------------------------------
# The directory where generated paper summaries and research plans are cached on disk.
# Default: .academicforge_cache
ACADEMICFORGE_CACHE_DIR=.academicforge_cache

# Cache Time-To-Live (expiry) in seconds.
# Default: 604800 (7 days)
ACADEMICFORGE_CACHE_TTL_SECONDS=604800

# Maximum number of cache files allowed before cleanup logic is triggered.
# Default: 500
ACADEMICFORGE_CACHE_MAX_FILES=500

# ------------------------------------------------------------------------------
# Frontend & Backend Communication
# ------------------------------------------------------------------------------
# The public or local URL where the FastAPI backend server is hosting its API.
# The Streamlit frontend client uses this URL to send requests.
# Default: http://localhost:8000
ACADEMICFORGE_BACKEND_URL=http://localhost:8000
